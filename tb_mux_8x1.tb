`timescale 1ns/1ps;
module tb_mux_8x1;
reg [7:0] i;
reg [2:0] S;
wire y;
mux_8x1 uut(i, S, y);
initial begin
i = 8'b11101010;
S = 3'b000; #10;
S = 3'b001; #10;
S = 3'b010; #10;
S = 3'b011; #10;
S = 3'b100; #10;
S = 3'b101; #10;
S = 3'b110; #10;
S = 3'b111; #10;
 $finish;
end
endmodule